<ProxyEndpoint name="default">
  <PreFlow name="PreFlow">
    <Request>
      <Step><Name>EV-Bearer</Name></Step>
      <Step><Name>VJ-VerifyUser</Name></Step>
      <Step><Name>AM-UserId</Name></Step>
      <Step><Name>VAK-VerifyKey</Name></Step>
      <Step><Name>EV-Model</Name></Step>
      <Step>
        <Name>RF-ModelNotAllowed</Name>
        <Condition>!(requested.model ~ "gemini-*")</Condition>
      </Step>
      <Step><Name>Q-Requests</Name></Step>
    </Request>
    <Response/>
  </PreFlow>
  <Flows/>
  <PostFlow name="PostFlow"><Request/><Response/></PostFlow>
  <HTTPProxyConnection>
    <BasePath>/llm</BasePath>
  </HTTPProxyConnection>
  <RouteRule name="default">
    <TargetEndpoint>default</TargetEndpoint>
  </RouteRule>
</ProxyEndpoint>
